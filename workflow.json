    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "try {\n    const item = $input.item.json;\n    let rawText = '';\n    if (item.content && item.content.parts && item.content.parts.length > 0) {\n        rawText = item.content.parts[0].text || '';\n    }\n    if (!rawText) {\n        return {\n            json: {\n                ...item,\n                subject: '',\n                body: '',\n                parse_error: 'Empty response from Gemini'\n            }\n        };\n    }\n    const cleanedString = rawText.replace(/```json|```/g, '').trim();\n    const emailData = JSON.parse(cleanedString);\n    return {\n        json: {\n            ...item,\n            subject: emailData.subject || '',\n            body: emailData.body || '',\n            parse_error: ''\n        }\n    };\n} catch (error) {\n    const item = $input.item.json;\n    return {\n        json: {\n            ...item,\n            subject: '',\n            body: '',\n            parse_error: 'Failed to parse Gemini response: ' + String(error)\n        }\n    };\n}"
      },
