    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst rawHtml = item.data || item.body || \"\";\n\n// Guard clause: Return empty string if input is empty or invalid\nif (!rawHtml || typeof rawHtml !== 'string' || rawHtml.trim() === '') {\n    return {\n        json: {\n            ...item,\n            clean_website_text: \"\"\n        }\n    };\n}\n\n// 1. Strip non-content blocks (scripts, styles, headers, footers, SVGs)\nlet clean = rawHtml\n    .replace(/<script[\\s\\S]*?<\\/script>/gi, \"\")\n    .replace(/<style[\\s\\S]*?<\\/style>/gi, \"\")\n    .replace(/<svg[\\s\\S]*?<\\/svg>/gi, \"\")\n    .replace(/<noscript[\\s\\S]*?<\\/noscript>/gi, \"\")\n    .replace(/<header[\\s\\S]*?<\\/header>/gi, \"\") // Removes top navigation menus\n    .replace(/<footer[\\s\\S]*?<\\/footer>/gi, \"\"); // Removes privacy policies/social links in footer\n\n// 2. Strip HTML tags\nclean = clean.replace(/<[^>]+>/g, \" \");\n\n// 3. Decode common HTML entities to make text natural for Gemini\nconst entities = {\n    '&nbsp;': ' ', '&amp;': '&', '&lt;': '<', '&gt;': '>',\n    '&quot;': '\"', '&#39;': \"'\", '&apos;': \"'\", '&ndash;': '-',\n    '&mdash;': '-', '&copy;': ''\n};\nfor (const [entity, replacement] of Object.entries(entities)) {\n    clean = clean.replaceAll(entity, replacement);\n}\n\n// 4. Normalize spacing and remove backslashes\nclean = clean\n    .replace(/\\s+/g, \" \")\n    .replace(/\\\\/g, \"\")\n    .trim();\n\n// 5. Restrict to a safe context size (e.g., 2000 characters) to save Gemini free tier tokens\nclean = clean.substring(0, 2000);\n\nreturn {\n    json: {\n        ...item,\n        clean_website_text: clean\n    }\n};"
      },
