    {
      "parameters": {
        "jsCode": "const delayPerLead = 8000; // 8 seconds between leads\nconst results = [];\n\nfor (let i = 0; i < $input.all().length; i++) {\n  // Add delay before processing (skip for first lead)\n  if (i > 0) {\n    const start = Date.now();\n    while (Date.now() - start < delayPerLead) {}\n  }\n  \n  results.push({\n    json: {\n      ...$input.all()[i].json,\n      _index: i\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2000,
        192
      ],
      "id": "34385832-6168-4e61-af25-c43808d70dc8",
      "name": "Index"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\n\nconst errorObj = item.error || {};\nlet errorMessage = '';\nlet httpStatusCode = 0;\n\nif (typeof errorObj === 'string') {\n    errorMessage = errorObj;\n} else if (typeof errorObj === 'object') {\n    errorMessage = errorObj.message || '';\n    httpStatusCode = errorObj.httpStatus || errorObj.status || errorObj.statusCode || 0;\n}\n\nif (!httpStatusCode && errorMessage) {\n    const statusMatch = errorMessage.match(/status\\s*(code)?\\s*:?\\s*(\\d{3})/i);\n    if (statusMatch) {\n        httpStatusCode = parseInt(statusMatch[2]);\n    }\n}\n\nconst currentRetryCount = parseInt(item.retry_count) || 0;\n\n// Detect error source from error message and item data\nlet errorSource = 'unknown';\n\nif (httpStatusCode === 401 || httpStatusCode === 403) {\n    if (errorMessage.toLowerCase().includes('generativelanguage') ||\n        errorMessage.toLowerCase().includes('gemini') ||\n        errorMessage.toLowerCase().includes('api_key') ||\n        errorMessage.toLowerCase().includes('api key')) {\n        errorSource = 'Gemini API';\n    } else {\n        errorSource = 'Gmail Send';\n    }\n} else if (errorMessage.toLowerCase().includes('gmail') ||\n           errorMessage.toLowerCase().includes('smtp') ||\n           errorMessage.toLowerCase().includes('recipient') ||\n           errorMessage.toLowerCase().includes('invalid email') ||\n           errorMessage.toLowerCase().includes('quota') ||\n           errorMessage.toLowerCase().includes('daily limit')) {\n    errorSource = 'Gmail Send';\n} else if (errorMessage.toLowerCase().includes('generativelanguage') ||\n           errorMessage.toLowerCase().includes('generative-ai') ||\n           errorMessage.toLowerCase().includes('gemini') ||\n           errorMessage.toLowerCase().includes('models/') ||\n           errorMessage.toLowerCase().includes('generatecontent')) {\n    errorSource = 'Gemini API';\n} else if (errorMessage.toLowerCase().includes('econnrefused') ||\n           errorMessage.toLowerCase().includes('econnreset') ||\n           errorMessage.toLowerCase().includes('enotfound') ||\n           errorMessage.toLowerCase().includes('getaddrinfo') ||\n           errorMessage.toLowerCase().includes('network')) {\n    if (item.clean_website_text !== undefined || item.website) {\n        errorSource = 'Scrape Website';\n    } else {\n        errorSource = 'Gemini API';\n    }\n} else if (errorMessage.toLowerCase().includes('timeout') ||\n           errorMessage.toLowerCase().includes('socket hang up')) {\n    if (item.clean_website_text !== undefined) {\n        errorSource = 'Scrape Website';\n    } else {\n        errorSource = 'Gemini API';\n    }\n} else if (errorMessage.toLowerCase().includes('url') ||\n           errorMessage.toLowerCase().includes('parameter')) {\n    errorSource = 'Scrape Website';\n} else {\n    if (item.subject !== undefined || item.body !== undefined) {\n        errorSource = 'Gmail Send';\n    } else if (item.clean_website_text !== undefined) {\n        errorSource = 'Gemini API';\n    } else {\n        errorSource = 'Scrape Website';\n    }\n}\n\n// Classify error type\nlet errorType;\n\nif (httpStatusCode === 429) {\n    errorType = 'retryable';\n} else if (httpStatusCode >= 500 && httpStatusCode <= 599) {\n    errorType = 'retryable';\n} else if (httpStatusCode === 404) {\n    errorType = 'permanent';\n} else if (httpStatusCode >= 400 && httpStatusCode < 500) {\n    errorType = 'permanent';\n} else if (errorMessage.toLowerCase().includes('timeout') ||\n           errorMessage.toLowerCase().includes('econnrefused') ||\n           errorMessage.toLowerCase().includes('econnreset') ||\n           errorMessage.toLowerCase().includes('network') ||\n           errorMessage.toLowerCase().includes('socket')) {\n    errorType = 'retryable';\n} else if (errorMessage.toLowerCase().includes('empty') ||\n           errorMessage.toLowerCase().includes('missing') ||\n           errorMessage.toLowerCase().includes('invalid parameter') ||\n           errorMessage.toLowerCase().includes('required') ||\n           errorMessage.toLowerCase().includes('cannot be empty')) {\n    errorType = 'permanent';\n} else {\n    errorType = 'retryable';\n}\n\n// Decide action\nlet action;\nlet newStatus;\nlet nextRetryCount;\n\nif (errorType === 'permanent') {\n    action = 'stop';\n    newStatus = 'FAILED_PERMANENTLY';\n    nextRetryCount = currentRetryCount + 1;\n} else if (currentRetryCount < 3) {\n    action = 'retry';\n    newStatus = 'retrying';\n    nextRetryCount = currentRetryCount + 1;\n} else {\n    action = 'stop';\n    newStatus = 'retry_later';\n    nextRetryCount = currentRetryCount;\n}\n\nconst waitMs = (action === 'retry')\n    ? Math.floor(Math.random() * 30000) + 30000\n    : 0;\n\nconst shortError = String(errorMessage).substring(0, 300);\n\nreturn {\n    json: {\n        ...item,\n        retry_count: nextRetryCount,\n        _action: action,\n        _new_status: newStatus,\n        _error_type: errorType,\n        _error_source: errorSource,\n        _wait_ms: waitMs,\n        _error_message: shortError,\n        error_log: '[' + errorSource + '] ' + errorType + ': ' + shortError\n    }\n};"
      },
